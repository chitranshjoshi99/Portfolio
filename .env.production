# Committed build fallback so `vite build` always has VITE_SITE_URL defined
# (an unreplaced %VITE_SITE_URL% token in index.html crashes vite:build-html).
# The Vercel dashboard env var (process.env) OVERRIDES this at build time —
# set the real URL there. Update this placeholder only if you stop using Vercel env.
VITE_SITE_URL=https://your-app.vercel.app
